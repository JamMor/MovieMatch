{
  "name": "moviematch",
  "version": "1.0.0",
  "description": "Bundles ES6 modules into a single file using Webpack.",
  "private": true,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "bundle-dev": "webpack --config ./webpack/webpack.dev.config.js --profile --json=./webpack/compilation-stats.dev.json",
    "bundle-prod": "webpack --config ./webpack/webpack.prod.config.js --profile --json=./webpack/compilation-stats.prod.json",
    "bundle-purge": "webpack --config ./webpack/webpack.purge.config.js --profile --json=./webpack/compilation-stats.purge.json",
    "bundle-deploy": "webpack --config ./webpack/webpack.deploy.config.js --profile --json=./webpack/compilation-stats.deploy.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JamMor/MovieMatch.git"
  },
