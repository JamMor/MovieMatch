  },
  "homepage": "https://github.com/JamMor/MovieMatch#readme",
  "devDependencies": {
    "css-loader": "^6.11.0",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "glob": "^11.0.3",
    "mini-css-extract-plugin": "^2.7.6",
    "purgecss-webpack-plugin": "^7.0.2",
    "terser-webpack-plugin": "^5.3.9",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-merge": "^5.9.0"
  }
